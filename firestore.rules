rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ───
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['directivo', 'secretario'];
    }

    function isCoach() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'dt';
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ─── Users ───
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ─── Store Products ───
    match /store_products/{productId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ─── Store Orders ───
    match /store_orders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.buyerId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.buyerId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.buyerId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // ─── Settings ───
    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ─── Notifications ───
    match /notifications/{notificationId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ─── Events & Announcements ───
    match /events/{eventId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /announcements/{announcementId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ─── Payments ───
    match /payments/{paymentId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    // ─── Novedades ───
    match /novedades/{novedadId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ─── Match & Sports Domain ───
    match /matches/{matchId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isCoach();
      
      // Subcollections for match
      match /convocatoria/{playerId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin() || isCoach();
      }
      match /lineup/{playerId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin() || isCoach();
      }
    }

    match /fixtures/{fixtureId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isCoach();
    }

    match /league_reports/{reportId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isCoach();
    }

    match /coach_reports/{reportId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isCoach();
    }

    match /players/{playerId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isCoach();
    }

    // ─── Default: deny everything else ───
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ─── Store Product Images ───
    // Admins can upload/delete product images
    match /store_products/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ─── Store Receipt Images ───
    // Authenticated users can upload receipts, admins can read them
    match /store_receipts/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ─── Default: deny everything else ───
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

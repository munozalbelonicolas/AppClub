rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ─── Helper Functions ───
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['directivo', 'secretario'];
    }

    // ─── Store Product Images ───
    match /store_products/{allPaths=**} {
      allow read: if isAuthenticated();
      // Only Admins can upload or delete product images
      allow write: if isAdmin();
    }

    // ─── Store Receipt Images ───
    match /store_receipts/{allPaths=**} {
      // Authenticated users can upload receipts, admins can read all
      allow read: if isAuthenticated(); // Or restrict to isAdmin if receipts are private
      // Users can only write if it's less than 5MB and is an image
      allow write: if isAuthenticated() && 
                   request.resource.size < 5 * 1024 * 1024 &&
                   request.resource.contentType.matches('image/.*');
    }

    // ─── Default: deny everything else ───
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
